# Contraseña del panel de administración. Se compara con bcrypt al login.
# Cambiala antes de exponer la app.
VITE_ADMIN_PASSWORD=adminadmin

# Base path para GitHub Pages. Si tu repo se llama "salud-7", poné:
#   VITE_BASE=/salud-7/
# Dejar vacío o './' para desarrollo local y apps instaladas.
# El workflow de GitHub Actions lo setea automáticamente.
VITE_BASE=./

# Si querés permitir que la app se sirva por HTTP en desarrollo (sin TLS),
# activá esto. NO recomendado en producción: la PWA no se podrá instalar.
# VITE_ALLOW_INSECURE=true
